{
  "manifest_version": 3,
  "name": "EncodeX - TikTok HQ Upload",
  "version": "2.0.0",
  "description": "Server-side FFmpeg processing bypasses TikTok's client-side compression for maximum quality uploads at 60FPS.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "EncodeX HQ Upload"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [ "https://www.tiktok.com/*" ],
      "js": [ "content.js" ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.tikwm.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.tiktokcdn-us.com/*",
    "https://encodex-api-production.up.railway.app/*"
  ],
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "downloads",
    "alarms",
    "unlimitedStorage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [ "inject.js" ],
      "matches": [ "<all_urls>" ]
    }
  ]
}
